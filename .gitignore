# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
*.egg-info/
.pytest_cache/
.mypy_cache/

# Patcher build / work products (CIAs, RomFS trees, LayeredFS, reports)
out/

# Optional PNG-pack scratch (not gold)
cache/

# Release artifacts: keep docs + translation source; ignore large generated bins
release/**
!release/README.md

# Downloaded / cloned tooling — keep EngPatcher-owned scripts + vendored pack/SMS deps
tools/*
!tools/README.md
!tools/deploy_*.py
!tools/deploy_common.py
!tools/rebuild_bake_img.py
!tools/restore_*.ps1
!tools/nuclear_jp_to_x.py
!tools/mdcutil.py
!tools/translate_sms_en.py
!tools/nlpp-tools/
!tools/nlpp-tools/**
!tools/Trb2xlsx/
!tools/Trb2xlsx/**
# Trb2xlsx build / IDE junk (lookup.txt + sources stay tracked)
tools/Trb2xlsx/**/bin/
tools/Trb2xlsx/**/obj/
tools/Trb2xlsx/**/packages/
tools/Trb2xlsx/.vs/
tools/Trb2xlsx/**/.vs/

# Vendored decrypt.exe + credits (Batch CIA 3DS Decryptor Redux)
!tools/Batch-CIA-3DS-Decryptor-Redux/
!tools/Batch-CIA-3DS-Decryptor-Redux/**

# Game dumps & intermediates (never commit)
*.cia
*.cxi
*.cci
*.3ds
*.app
img.bin
*.ncch

# Archives
*.rar
*.7z
*.zip
# Keep vendored NLPPATCH plugin/note zips trackable
!vendor/**/*.zip

# OS / editor
.DS_Store
Thumbs.db
desktop.ini
*.swp
*~
.idea/
.vscode/

tools/Trb2xlsx/**/*.csproj.user
